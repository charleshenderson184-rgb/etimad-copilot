# Public — bundled into the client. Safe to expose.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase — required for real auth. Without these the frontend uses
# a localStorage-backed dev auth fallback.
# Get from Supabase: Settings → API → Project URL and "anon" public key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
