# ─── Core ───────────────────────────────────────────────────
# Sonnet by default; set ANTHROPIC_API_KEY to enable real AI generation.
# Without it, proposal generation will fail but the rest of the app works.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Local dev uses SQLite. In production, point this at your Postgres
# connection string (Supabase / Railway / RDS). e.g.
#   postgresql+psycopg2://USER:PASS@HOST:5432/DBNAME
DATABASE_URL=sqlite:///./etimad.db

# Where uploaded RFP PDFs and company docs live on the server.
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# ─── Frontend URL (used in email links, Stripe redirects, invites) ──
FRONTEND_URL=http://localhost:3000

# ─── CORS ───────────────────────────────────────────────────
# Comma-separated list of EXACT allowed origins.
# Production example:
#   CORS_ORIGINS=https://app.yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Optional regex for Vercel preview deploys (no quotes, no commas):
#   CORS_ORIGIN_REGEX=https://etimad-copilot-.*\.vercel\.app
CORS_ORIGIN_REGEX=

# ─── Auth (Supabase) ────────────────────────────────────────
# When false, the backend runs in single-user dev mode. Flip to true in prod.
AUTH_ENABLED=false
# Get from Supabase: Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Billing (Stripe) ───────────────────────────────────────
# When false, /api/billing/* returns dev_mode responses and skips Stripe.
BILLING_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Create three recurring Price IDs in Stripe and paste them here.
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_ENTERPRISE=

# ─── Email (Resend) ─────────────────────────────────────────
# When false, emails are logged to stdout instead of being sent.
EMAIL_ENABLED=false
RESEND_API_KEY=
EMAIL_FROM=Etimad Copilot <hello@yourdomain.com>

# ─── Object storage (S3 / Cloudflare R2 / MinIO) ────────────
# Default "local" writes uploads to UPLOAD_DIR on disk. In production set
# this to "s3" so files survive container restarts and scale across replicas.
STORAGE_BACKEND=local
# When STORAGE_BACKEND=s3 these are required:
S3_BUCKET=
# For R2: "auto"  | For AWS: e.g. "eu-west-1"  | For MinIO: "us-east-1"
S3_REGION=auto
# R2:    https://<account-id>.r2.cloudflarestorage.com
# AWS:   leave blank (boto3 uses default AWS endpoint)
# MinIO: http://minio:9000
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Optional folder prefix inside the bucket (e.g. "prod/" or "staging/")
S3_KEY_PREFIX=

# ─── Etimad scraper (off by default) ────────────────────────
ETIMAD_SCRAPER_ENABLED=false
